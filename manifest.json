{
  "manifest_version": 3,
  "name": "JSON Side",
  "version": "1.0.0",
  "description": "JSON formatter, diff, converter and query tool - Select JSON text on any page, right-click to format in a new tab",
  "permissions": [
    "contextMenus",
    "storage",
    "bookmarks"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "JSON Side"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["license.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
