{
  "manifest_version": 3,
  "name": "JSON Side",
  "version": "1.0.0",
  "description": "JSON 格式化、对比、转换、查询工具 - 选中网页上的 JSON 文本，右键自动在新标签页打开格式化显示",
  "permissions": [
    "contextMenus",
    "storage",
    "bookmarks"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "JSON Side"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["license.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
